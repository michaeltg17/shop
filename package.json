{
  "name": "angular-app",
  "version": "1.0.0",
  "scripts": {
    "prettier:check": "prettier --check \"src/**/*.{ts,html,css,scss,json,md}\"",
    "prettier": "prettier --write \"src/**/*.{ts,html,css,scss,json,md}\"",
    "lint": "ng lint",
    "test": "ng test --no-watch",
    "test:coverage": "ng test --no-watch --coverage",
    "build": "ng build",
    "start": "ng serve",
    "playwright": "playwright test",
    "playwright:install": "npx playwright install"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "~21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/material": "~21.2.5",
    "@angular/platform-browser": "^21.2.7",
    "@angular/router": "^21.2.7",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@playwright/test": "^1.43.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.2.2",
    "@vitest/coverage-v8": "^4.1.4",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.2.0",
    "jsdom": "^27.1.0",
    "msw": "^2.12.7",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.50.1",
    "vitest": "^4.0.8"
  },
  "devDependenciesMeta": {
    "@playwright/test": {
      "optional": false
    }
  },
  "playwright": {
    "browsers": [
      "chromium",
      "firefox",
      "webkit"
    ]
  },
  "msw": {
    "workerDirectory": [
      "src"
    ]
  }
}
